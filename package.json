{
  "name": "cv-lint",
  "private": true,
  "version": "0.1.0",
  "description": "ATS resume analyzer – CV Lint",
  "type": "module",
  "workspaces": [
    "apps/frontend",
    "apps/backend"
  ],
  "scripts": {
    "dev:frontend": "npm --prefix apps/frontend run dev",
    "build:frontend": "npm --prefix apps/frontend run build",
    "start:frontend": "npm --prefix apps/frontend run start",
    "dev:backend": "npm --prefix apps/backend run start:dev",
    "build:backend": "npm --prefix apps/backend run build",
    "start:backend": "node dist/main.js"
  }
}
